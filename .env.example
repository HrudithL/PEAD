# Copy to .env and adjust for your machine. PEAD reads these to locate data that
# lives OUTSIDE the repository. Nothing here is committed (.env is gitignored).

# Equities data (master_stock.csv, IBES_Summary_*.csv). Defaults to the sibling
# "Data Source" folder if unset.
BEI_DATA_DIR=C:\Users\hrudi\Documents\BEI\Data Source

# OptionMetrics parquet root (year-partitioned opprcd/secprd/... + secnmd map).
# If unset, the resolver falls back to a built-in candidate list.
OPTIONMETRICS_DIR=D:\OptionMetrics\parquet

# WRDS credentials for the sub-sample drift-ML pipeline (pead/sub_sampling_ml).
# Used to pull CRSP/Compustat once; results are cached as CSV under WRDS_CACHE_DIR.
WRDS_USERNAME=your_wrds_username
WRDS_PASSWORD=your_wrds_password
# Where cached WRDS pulls live (defaults to "<BEI_DATA_DIR>\wrds_cache" if unset).
WRDS_CACHE_DIR=C:\Users\hrudi\Documents\BEI\Data Source\wrds_cache
